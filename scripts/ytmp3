#!/bin/sh

set -eu

usage() {
	printf 'usage: %s [YouTube URL]\n' "${0##*/}" >&2
	printf '%s\n' '       With no URL, a copied YouTube URL is used automatically on X11 or Wayland.' >&2
	printf '%s\n' '       If the clipboard has no URL, you will be prompted for one.' >&2
	printf '%s\n' '       MP3s are saved in ~/Music/YouTube by default.' >&2
}

case "${1:-}" in
	-h|--help)
		usage
		exit 0
		;;
esac

missing_tools=
need_ytdlp=0
need_ffmpeg=0
for tool in yt-dlp ffmpeg ffprobe; do
	if ! command -v "$tool" >/dev/null 2>&1; then
		if [ -n "$missing_tools" ]; then
			missing_tools="$missing_tools, $tool"
		else
			missing_tools=$tool
		fi
		case "$tool" in
			yt-dlp) need_ytdlp=1 ;;
			ffmpeg|ffprobe) need_ffmpeg=1 ;;
		esac
	fi
done

if [ -n "$missing_tools" ]; then
	printf '%s\n' \
		"ytmp3 cannot start. Missing commands: $missing_tools" \
		'' \
		'Install the missing software, then run ytmp3 again:' >&2

	if [ "$need_ytdlp" -eq 1 ]; then
		printf '%s\n' '  - yt-dlp' >&2
	fi
	if [ "$need_ffmpeg" -eq 1 ]; then
		printf '%s\n' '  - FFmpeg (provides ffmpeg and ffprobe)' >&2
	fi

	if ! command -v qjs >/dev/null 2>&1; then
		printf '%s\n' '  - QuickJS (provides qjs; optional but recommended)' >&2
	fi

	if command -v notify-send >/dev/null 2>&1 && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]; then
		notify-send -u critical 'ytmp3 cannot start' \
			"Missing: $missing_tools. See the terminal for installation details."
	fi
	exit 127
fi

if ! command -v qjs >/dev/null 2>&1; then
	printf '%s\n' \
		'ytmp3: QuickJS (qjs) is not installed.' \
		'        It is optional, but recommended for full YouTube support.' >&2
fi

case "$#" in
	0)
		url=
		clipboard_url=
		clipboard_tool=
		if [ -t 0 ] && [ -n "${WAYLAND_DISPLAY:-}" ]; then
			if command -v wl-paste >/dev/null 2>&1; then
				clipboard_url=$(wl-paste --no-newline --type text 2>/dev/null || true)
				clipboard_tool=wl-paste
			elif [ -z "${DISPLAY:-}" ] || ! command -v xclip >/dev/null 2>&1; then
				printf '%s\n' \
					'ytmp3: automatic Wayland clipboard reading needs wl-paste.' \
					'        Install wl-clipboard, or paste the URL at the prompt.' >&2
			fi
		fi

		if [ -t 0 ] && [ -z "$clipboard_url" ] && [ -n "${DISPLAY:-}" ] && command -v xclip >/dev/null 2>&1; then
			clipboard_url=$(xclip -selection clipboard -out 2>/dev/null || true)
			clipboard_tool=xclip
		elif [ -t 0 ] && [ -z "${WAYLAND_DISPLAY:-}" ] && [ -n "${DISPLAY:-}" ] && ! command -v xclip >/dev/null 2>&1; then
			printf '%s\n' \
				'ytmp3: automatic X11 clipboard reading needs xclip.' \
				'        Install xclip, or paste the URL at the prompt.' >&2
		fi

		if [ -n "$clipboard_url" ]; then
			case "$clipboard_url" in
				http://youtube.com/*|https://youtube.com/*|\
				http://*.youtube.com/*|https://*.youtube.com/*|\
				http://youtu.be/*|https://youtu.be/*)
					url=$clipboard_url
					printf 'Using the YouTube URL from the clipboard via %s.\n' "$clipboard_tool"
					;;
			esac
		fi

		if [ -z "$url" ] && [ -t 0 ]; then
			printf '%s' 'YouTube URL: ' >&2
		fi
		if [ -z "$url" ] && { ! IFS= read -r url || [ -z "$url" ]; }; then
			usage
			exit 2
		fi
		;;
	1)
		url=$1
		;;
	*)
		usage
		exit 2
		;;
esac

output_dir=${YTMP3_DIR:-"$HOME/Music/YouTube"}
mkdir -p "$output_dir"

printf 'Saving the best available audio as MP3 in:\n  %s\n\n' "$output_dir"

set --
if command -v qjs >/dev/null 2>&1; then
	set -- --js-runtimes "quickjs:$(command -v qjs)"
fi

yt-dlp --ignore-config "$@" \
	--no-playlist \
	--extract-audio \
	--format 'bestaudio/best' \
	--audio-format mp3 \
	--audio-quality 0 \
	--embed-metadata \
	--embed-thumbnail \
	--trim-filenames 180 \
	--progress \
	--newline \
	--output "$output_dir/%(title)s [%(id)s].%(ext)s" \
	--print 'after_move:Saved: %(filepath)s' \
	-- "$url"

printf '%s\n' 'Done.'

if command -v notify-send >/dev/null 2>&1 && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]; then
	notify-send 'YouTube MP3 saved' "$output_dir" || true
fi
